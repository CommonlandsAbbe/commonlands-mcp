# Non-secret deploy metadata
ENVIRONMENT=staging
VERSION=0.1.0
GIT_SHA=replace-at-deploy-time

# Secret names documented only. Do not place real values here.
# AWS_ACCESS_KEY_ID=        # read-only IAM user key id (Worker secret)
# AWS_SECRET_ACCESS_KEY=    # read-only IAM user secret (Worker secret)
# AWS_SESSION_TOKEN=        # only if using temporary STS credentials

# Live sensor catalog (DynamoDB). Table name + region are non-secret (set in
# wrangler.toml [vars]); the AWS_* credentials above are the only secrets.
# SENSOR_DDB_TABLE=SensorData-orz4gwks4bef7engytv7spr2ha-dev
# SENSOR_DDB_REGION=us-west-2
# SHOPIFY_STOREFRONT_TOKEN=
# SHOPIFY_ADMIN_READ_TOKEN=
# SHOPIFY_CART_MCP_ENDPOINT=https://commonlands-camera-components.myshopify.com/api/mcp
# SHOPIFY_CHECKOUT_MCP_ENDPOINT=https://commonlands.com/api/checkout/mcp
# SHOPIFY_UCP_AGENT_PROFILE=https://mcp.commonlands.com/.well-known/ucp
# Live FoV Lambda backend (non-secret vars + secret name)
# FOV_LIVE_BACKEND_ENABLED=false
# FOV_LAMBDA_ENDPOINT=https://ia97wrz7ag.execute-api.us-west-2.amazonaws.com/default/fov
# FOV_API_KEY=store-as-cloudflare-secret-only
